# =====================================================================
# SPILL — ENVIRONMENT VARIABLES CONFIG
# =====================================================================
# Rename this file to ".env" to override the mock database engine 
# and connect directly to a live Supabase project.
# =====================================================================

# 1. Credentials (from Settings -> API in your Supabase dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 2. REQUIRED DASHBOARD SETUP:
# Go to your Supabase Dashboard -> Authentication -> Providers -> Anonymous
# and ENABLE "Anonymous Sign-ins". Save changes.
# The app will automatically onboard guest sessions on first launch!

# 3. AI IMAGE MODERATION SETUP:
# Get a Gemini API key from Google AI Studio.
# Set it in your local .env file (if running functions locally) and in your Supabase project secrets:
# Command: supabase secrets set GEMINI_API_KEY=your-api-key
GEMINI_API_KEY=your-gemini-api-key-here

